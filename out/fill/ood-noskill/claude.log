    258	# codepoint classes for the general (rule-based) transducer
    259	VOWEL_CP = set("aeiouAO:")          # ':' (length) behaves as a vowel
    260	BREVE_CP = "̆"                       # U+0306 combining breve (whispered vowel)
    261	
    262	
    263	def build_general(chars):
    264	    """A rule-based transducer that inflects ANY lemma over the alphabet.
    265	    Used only for lemmas absent from the training lexicon."""
    266	    cons = [c for c in chars if c not in VOWEL_CP and c != BREVE_CP]
    267	    vowels = [c for c in chars if c in VOWEL_CP]
    268	
    269	    def cls(members):
    270	        return "(" + "|".join("'%s':'%s'" % (esc(c), esc(c)) for c in members) + ")"
    271	
    272	    ANY = cls(chars) + "*"                      # identity copy of any string
    273	    ENDVOW = ANY + " " + cls(vowels)            # ...vowel  (plain vowel final)
    274	    ENDCONS = ANY + " " + cls(cons)             # ...consonant final
    275	    ENDBREVE = ANY + " '%s':''" % esc(BREVE_CP)  # ...breve -> drop breve
    276	    DELCONS = ANY + " (" + "|".join("'%s':''" % esc(c) for c in cons) + ")"
    277	
    278	    def stem(kind):
    279	        if kind == "id":
    280	            return ANY
    281	        if kind == "fut":
    282	            return "( %s '':'d' | %s '':'d' | %s '':'a' '':'d' )" % (ENDVOW, ENDBREVE, ENDCONS)
    283	        if kind == "imp":
    284	            return "( %s '':'ñ' | %s '':'ñ' | %s '':'i' '':'ñ' )" % (ENDVOW, ENDBREVE, ENDCONS)
    285	        if kind == "prf":
    286	            # ends in a vowel/breve -> unchanged; else drop final consonant
    287	            return "( %s | %s '%s':'%s' | %s )" % (ENDVOW, ANY, esc(BREVE_CP), esc(BREVE_CP), DELCONS)
    288	        raise ValueError(kind)

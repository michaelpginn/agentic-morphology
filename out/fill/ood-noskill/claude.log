    297	def build():
    298	    lem = collections.defaultdict(dict)
    299	    pos = collections.defaultdict(set)
    300	    with open(TRAIN, encoding="utf-8") as fh:
    301	        for line in fh:
    302	            line = line.rstrip("\n")
    303	            if not line:
    304	                continue
    305	            lemma, wf, feat = line.split("\t")
    306	            lem[lemma][feat] = wf
    307	            pos[lemma].add(feat.split(";")[0])
    308	
    309	    paths = []
    310	    for lemma, forms in lem.items():
    311	        combos = []
    312	        if "N" in pos[lemma]:
    313	            combos += N_COMBOS
    314	        if "V" in pos[lemma]:
    315	            combos += V_COMBOS
    316	        for feat in combos:
    317	            out = forms[feat] if feat in forms else predict(feat, forms)
    318	            if out is None:
    319	                continue
    320	            fa = atoms_feat(feat)
    321	            src = " ".join(fa + atoms_word(lemma))
    322	            dst = " ".join(fa + atoms_word(out))
    323	            paths.append("(%s):(%s)" % (src, dst))
    324	
    325	    # Compile in modest batches (a single huge alternation is pathologically
    326	    # slow to parse), then union + minimize.
    327	    BATCH = 150
    328	    fsts = [FST.re(" | ".join(paths[i:i + BATCH]))
    329	            for i in range(0, len(paths), BATCH)]
    330	    fst = fsts[0]
    331	    for g in fsts[1:]:
    332	        fst = fst.union(g)
    333	    fst = fst.determinize().minimize()
    334	    print("paths: %d   states: %d" % (len(paths), len(fst.states)))
